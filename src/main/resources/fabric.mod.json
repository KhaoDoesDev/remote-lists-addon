{
  "schemaVersion": 1,
  "id": "remote-lists-addon",
  "version": "${version}",
  "name": "Remote Lists Addon",
  "description": "An addon to control your friends list (and more) remotely via an API.",
  "authors": [
    {
      "name": "Khao",
      "contact": {
        "homepage": "https://khaodoes.dev/"
      }
    }
  ],
  "contact": {
    "sources": "https://github.com/KhaoDoesDev/remote-lists-addon"
  },
  "icon": "assets/remote-lists-addon/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "dev.khaodoes.remoteListsAddon.RemoteListsAddon"
    ]
  },
  "mixins": [
    "remote-lists-addon.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "225,25,25",
    "modmenu": {
      "parent": {
        "id": "meteor-client"
      }
    }
  },
  "depends": {
    "java": ">=21",
    "minecraft": ["${mc_version}"],
    "meteor-client": "*"
  }
}
